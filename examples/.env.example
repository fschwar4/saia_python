# Secrets only — this file should be in .gitignore.
# For structured configuration, use config.toml instead.

# SAIA API key — obtain yours via the KISSKI LLM Service booking page:
# https://kisski.gwdg.de/leistungen/2-02-llm-service/
SAIA_API_KEY=your-api-key-here

# Optional: a single default ARCANA ID (highest priority for "default")
# SAIA_ARCANA_ID=your-username/My-Arcana-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
