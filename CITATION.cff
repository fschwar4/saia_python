    given-names: Friedrich
    email: friedrich.schwarz@uni-goettingen.de
    orcid: "https://orcid.org/0009-0001-1167-8365"
    affiliation: >-
      Göttingen Campus Institute for Dynamics of Biological
      Networks (CIDBN), University of Göttingen, Göttingen,
      Germany
version: 0.4.1
date-released: "2026-05-30"
license: AGPL-3.0-only
repository-code: "https://github.com/fschwar4/saia_python"
url: "https://fschwar4.github.io/saia_python/"
